{
  "name": "@agent-track/api-server",
  "version": "0.1.0",
  "description": "REST API and WebSocket server for Agent Track Dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": ["api", "websocket", "server"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@agent-track/shared": "workspace:*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.16.0",
    "better-sqlite3": "^11.7.0",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.11",
    "@types/morgan": "^1.9.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
